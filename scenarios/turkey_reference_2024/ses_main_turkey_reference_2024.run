shell 'mkdir -p output_turkey_reference_2024';
model model/ses_main.mod;
data scenarios/turkey_reference_2024/ses_main_turkey_reference_2024.dat;
option solver gurobi;
option gurobi_options 'outlev=1';
option show_stats 1;

solve;

param OUTPUT_DIR symbolic := "output_turkey_reference_2024";
include scenarios/common/export_standard_outputs.run;
